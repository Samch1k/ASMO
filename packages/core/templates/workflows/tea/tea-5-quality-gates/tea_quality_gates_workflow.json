{
  "id": "tea_quality_gates_workflow",
  "name": "TEA Quality Gates Workflow",
  "description": "Define and implement quality gates for the development pipeline.",
  "trigger_condition": {
    "keywords": [
      "quality gates",
      "quality gate",
      "pipeline gates",
      "build gates",
      "качественные ворота"
    ],
    "task_types": [
      "quality_assurance",
      "devops",
      "pipeline"
    ],
    "required_skills": [
      "quality_gates",
      "test_strategy"
    ]
  },
  "context_dependencies": [
    "test-strategy",
    "architecture"
  ],
  "steps": [
    {
      "order": 1,
      "role_id": "test-architect",
      "phase": "gate_identification",
      "description": "Identify quality gate points in pipeline",
      "deliverables": [
        "gate_points"
      ],
      "exit_criteria": "Gate points identified for each stage",
      "timeout": "15m"
    },
    {
      "order": 2,
      "role_id": "test-architect",
      "phase": "criteria_definition",
      "description": "Define criteria for each gate",
      "deliverables": [
        "gate_criteria"
      ],
      "exit_criteria": "Pass/fail criteria defined for each gate",
      "timeout": "25m"
    },
    {
      "order": 3,
      "role_id": "test-architect",
      "phase": "thresholds",
      "description": "Set metric thresholds",
      "deliverables": [
        "threshold_config"
      ],
      "exit_criteria": "Thresholds set for all metrics",
      "timeout": "15m"
    },
    {
      "order": 4,
      "role_id": "devops",
      "phase": "implementation",
      "description": "Implement gates in CI/CD",
      "deliverables": [
        "gate_implementation"
      ],
      "exit_criteria": "Gates enforced in pipeline",
      "timeout": "30m"
    },
    {
      "order": 5,
      "role_id": "tech-writer",
      "phase": "documentation",
      "description": "Document gate procedures and bypass process",
      "deliverables": [
        "gate_documentation"
      ],
      "exit_criteria": "Gate procedures documented",
      "timeout": "15m"
    }
  ],
  "estimated_time": "1h 40m",
  "success_criteria": "Quality gates implemented and enforced"
}
