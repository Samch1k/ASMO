{
  "id": "tea_test_design_workflow",
  "name": "TEA Test Design Workflow",
  "description": "Design detailed test cases using various design techniques.",
  "trigger_condition": {
    "keywords": [
      "test design",
      "test cases",
      "test scenarios",
      "design tests",
      "дизайн тестов"
    ],
    "task_types": [
      "test_design",
      "testing",
      "quality_assurance"
    ],
    "required_skills": [
      "test_strategy",
      "testing"
    ]
  },
  "context_dependencies": [
    "test-strategy",
    "story"
  ],
  "steps": [
    {
      "order": 1,
      "role_id": "test-architect",
      "phase": "scenario_identification",
      "description": "Identify test scenarios from requirements",
      "deliverables": [
        "test_scenarios"
      ],
      "exit_criteria": "All scenarios identified",
      "timeout": "20m"
    },
    {
      "order": 2,
      "role_id": "tester",
      "phase": "boundary_analysis",
      "description": "Apply boundary value analysis",
      "deliverables": [
        "boundary_tests"
      ],
      "exit_criteria": "Boundary tests designed",
      "timeout": "20m"
    },
    {
      "order": 3,
      "role_id": "tester",
      "phase": "equivalence_partitioning",
      "description": "Apply equivalence partitioning",
      "deliverables": [
        "partition_tests"
      ],
      "exit_criteria": "Partition tests designed",
      "timeout": "20m"
    },
    {
      "order": 4,
      "role_id": "tester",
      "phase": "negative_testing",
      "description": "Design negative and error path tests",
      "deliverables": [
        "negative_tests"
      ],
      "exit_criteria": "Negative tests designed",
      "timeout": "20m"
    },
    {
      "order": 5,
      "role_id": "tester",
      "phase": "test_case_creation",
      "description": "Create detailed test cases",
      "deliverables": [
        "test_cases"
      ],
      "exit_criteria": "All test cases documented",
      "timeout": "30m"
    }
  ],
  "estimated_time": "1h 50m",
  "success_criteria": "Complete test cases ready for execution or automation"
}
