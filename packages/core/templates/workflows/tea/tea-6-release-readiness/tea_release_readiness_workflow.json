{
  "id": "tea_release_readiness_workflow",
  "name": "TEA Release Readiness Workflow",
  "description": "Assess release readiness and make go/no-go recommendation.",
  "trigger_condition": {
    "keywords": [
      "release readiness",
      "go no go",
      "release assessment",
      "ready to release",
      "готовность к релизу"
    ],
    "task_types": [
      "release_validation",
      "quality_assurance"
    ],
    "required_skills": [
      "release_readiness",
      "quality_gates"
    ]
  },
  "context_dependencies": [
    "test-strategy",
    "architecture",
    "epics"
  ],
  "steps": [
    {
      "order": 1,
      "role_id": "test-architect",
      "phase": "feature_check",
      "description": "Verify feature completeness",
      "deliverables": [
        "feature_checklist"
      ],
      "exit_criteria": "All features verified",
      "timeout": "15m"
    },
    {
      "order": 2,
      "role_id": "test-architect",
      "phase": "quality_metrics",
      "description": "Review quality metrics",
      "deliverables": [
        "quality_report"
      ],
      "exit_criteria": "Quality metrics assessed",
      "timeout": "20m"
    },
    {
      "order": 3,
      "role_id": "test-architect",
      "phase": "defect_review",
      "description": "Review open defects and risks",
      "deliverables": [
        "defect_analysis"
      ],
      "exit_criteria": "Defects categorized and risk assessed",
      "timeout": "15m"
    },
    {
      "order": 4,
      "role_id": "devops",
      "phase": "operational_check",
      "description": "Verify operational readiness",
      "deliverables": [
        "operational_checklist"
      ],
      "exit_criteria": "Monitoring and runbooks ready",
      "timeout": "15m"
    },
    {
      "order": 5,
      "role_id": "test-architect",
      "phase": "recommendation",
      "description": "Make go/no-go recommendation",
      "deliverables": [
        "release_recommendation"
      ],
      "exit_criteria": "Clear recommendation with rationale",
      "timeout": "15m"
    }
  ],
  "estimated_time": "1h 20m",
  "success_criteria": "Clear release recommendation with supporting data"
}
