{
  "id": "advanced_bug_fix",
  "name": "Advanced Bug Fix",
  "description": "Comprehensive bug resolution with root cause analysis and prevention",
  "trigger_condition": {
    "keywords": [
      "complex bug",
      "system bug",
      "critical bug",
      "production issue",
      "outage",
      "crash",
      "критический баг",
      "системная ошибка"
    ],
    "task_types": [
      "bug_fix",
      "incident_response"
    ],
    "required_skills": [
      "debugging",
      "root_cause_analysis",
      "system_design"
    ],
    "complexity_range": ["medium", "complex"]
  },
  "phases": {
    "investigation": {
      "description": "Deep investigation with root cause analysis",
      "description_ru": "Глубокое исследование с анализом первопричины",
      "order": 1,
      "intent_keywords": ["investigate", "analyze", "debug", "find cause", "исследовать", "проанализировать"]
    },
    "solution_design": {
      "description": "Design fix approach and prevention strategy",
      "description_ru": "Проектирование решения и стратегии предотвращения",
      "order": 2,
      "intent_keywords": ["design fix", "plan solution", "спроектировать решение"]
    },
    "implementation": {
      "description": "Implement fix with tests and error handling",
      "description_ru": "Реализация исправления с тестами",
      "order": 3,
      "intent_keywords": ["fix", "implement", "code", "исправить", "реализовать"]
    },
    "verification": {
      "description": "Thorough testing and regression validation",
      "description_ru": "Тщательное тестирование и проверка на регрессии",
      "order": 4,
      "intent_keywords": ["test", "verify", "validate", "regression", "тестировать", "проверить"]
    },
    "review": {
      "description": "Code review for quality and prevention",
      "description_ru": "Ревью кода на качество",
      "order": 5,
      "intent_keywords": ["review", "check code", "ревью", "проверить код"]
    }
  },
  "steps": [
    {
      "order": 1,
      "role_id": "debugger",
      "phase": "investigation",
      "description": "Deep investigation of the bug including system analysis",
      "deliverables": [
        "detailed_bug_report",
        "root_cause_analysis",
        "impact_assessment",
        "reproduction_steps"
      ],
      "exit_criteria": "Root cause identified with full understanding of system impact",
      "timeout": "45m",
      "phase_join_criteria": {
        "required_artifacts": [],
        "prerequisites": ["bug reported"],
        "context_indicators": ["bug", "error", "issue", "crash", "investigate"],
        "skip_if": ["root cause already known"]
      }
    },
    {
      "order": 2,
      "role_id": "architect",
      "phase": "solution_design",
      "description": "Design comprehensive fix that addresses root cause and prevents recurrence",
      "deliverables": [
        "fix_design",
        "prevention_strategy",
        "testing_strategy"
      ],
      "exit_criteria": "Fix approach approved with prevention measures defined",
      "timeout": "30m",
      "phase_join_criteria": {
        "required_artifacts": ["root cause analysis"],
        "prerequisites": ["root cause identified"],
        "context_indicators": ["design solution", "plan fix"],
        "skip_if": ["fix design exists", "simple fix"]
      }
    },
    {
      "order": 3,
      "role_id": "developer",
      "phase": "implementation",
      "description": "Implement fix with proper error handling and logging",
      "deliverables": [
        "code",
        "unit_tests",
        "integration_tests",
        "updated_documentation"
      ],
      "exit_criteria": "Fix implemented with comprehensive tests",
      "timeout": "60m",
      "phase_join_criteria": {
        "required_artifacts": ["fix design"],
        "prerequisites": ["fix approach approved"],
        "context_indicators": ["fix", "implement", "code"],
        "skip_if": ["fix already implemented"]
      }
    },
    {
      "order": 4,
      "role_id": "tester",
      "phase": "verification",
      "description": "Thorough testing including edge cases and regression testing",
      "deliverables": [
        "test_results",
        "regression_test_results",
        "performance_impact_analysis"
      ],
      "exit_criteria": "Bug verified as fixed with no regressions",
      "timeout": "45m",
      "phase_join_criteria": {
        "required_artifacts": ["fix implementation"],
        "prerequisites": ["fix implemented"],
        "context_indicators": ["test", "verify", "regression"],
        "skip_if": ["tests already pass"]
      }
    },
    {
      "order": 5,
      "role_id": "code-reviewer",
      "phase": "review",
      "description": "Review fix for quality and prevention measures",
      "deliverables": [
        "code_review_report",
        "improvement_suggestions"
      ],
      "exit_criteria": "Code reviewed and approved",
      "timeout": "20m",
      "phase_join_criteria": {
        "required_artifacts": ["fix code"],
        "prerequisites": ["fix exists"],
        "context_indicators": ["review", "check", "approve"],
        "skip_if": []
      }
    }
  ],
  "estimated_time": "3h 20m",
  "success_criteria": "Bug resolved, prevention measures in place, all tests passing, no regressions",
  "metadata": {
    "adaptive_phase_detection": true
  }
}
