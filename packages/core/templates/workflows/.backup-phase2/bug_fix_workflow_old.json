{
  "id": "bug_fix_workflow",
  "name": "Bug Fix Workflow",
  "description": "Debug → Fix → Test pipeline for bug fixes",
  "trigger_condition": {
    "keywords": [
      "bug",
      "error",
      "broken",
      "fail",
      "crash",
      "fix",
      "исправ",
      "ошибка",
      "баг"
    ],
    "task_types": [
      "bug_fix"
    ],
    "required_skills": [
      "debugging",
      "code_writing"
    ]
  },
  "steps": [
    {
      "order": 1,
      "role_id": "debugger",
      "phase": "investigation",
      "description": "Investigate root cause of the bug",
      "deliverables": [
        "bug_report",
        "root_cause_analysis"
      ],
      "exit_criteria": "Root cause identified and documented",
      "timeout": "15m"
    },
    {
      "order": 2,
      "role_id": "developer",
      "phase": "fix_implementation",
      "description": "Implement the fix based on investigation",
      "deliverables": [
        "code",
        "unit_tests"
      ],
      "exit_criteria": "Fix implemented and unit tests pass",
      "timeout": "30m"
    },
    {
      "order": 3,
      "role_id": "tester",
      "phase": "verification",
      "description": "Verify bug is fixed with E2E tests",
      "deliverables": [
        "test_results"
      ],
      "exit_criteria": "Bug no longer reproduces in E2E tests",
      "timeout": "20m"
    }
  ],
  "estimated_time": "1h 5m",
  "success_criteria": "All tests pass and bug is resolved"
}