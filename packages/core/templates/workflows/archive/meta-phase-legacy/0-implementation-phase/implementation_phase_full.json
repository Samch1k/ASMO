{
  "id": "implementation_phase_full",
  "name": "Full Implementation Phase",
  "description": "Complete Implementation Phase: Code Generation → Testing → Code Review → Quality Gate. Fully automated, 1.5-2 weeks. Requires Discovery Phase artifacts.",
  "trigger_condition": {
    "keywords": [
      "implement",
      "build",
      "develop",
      "implementation phase",
      "code generation",
      "реализация",
      "разработка",
      "имплементация"
    ],
    "task_types": [
      "implementation",
      "development",
      "coding"
    ],
    "required_skills": [
      "coding",
      "testing",
      "code_review"
    ],
    "complexity_range": ["medium", "complex", "enterprise"]
  },
  "context_dependencies": [
    "prd_document",
    "architecture_document",
    "api_contracts"
  ],
  "phases": {
    "code_generation": {
      "description": "Generate code per architecture: React components, API endpoints, DB migrations",
      "description_ru": "Генерация кода по архитектуре: React компоненты, API endpoints, миграции БД",
      "order": 1,
      "intent_keywords": ["code", "implement", "generate", "build", "код", "реализовать"]
    },
    "testing": {
      "description": "Generate and run tests: unit, integration, E2E",
      "description_ru": "Генерация и запуск тестов: unit, integration, E2E",
      "order": 2,
      "intent_keywords": ["test", "coverage", "unit", "integration", "тест", "покрытие"]
    },
    "code_review": {
      "description": "Code quality analysis, security vulnerabilities, coding standards",
      "description_ru": "Анализ качества кода, уязвимости безопасности, стандарты",
      "order": 3,
      "intent_keywords": ["review", "quality", "security", "standards", "ревью", "качество"]
    },
    "quality_gate": {
      "description": "Final validation: all tests pass, coverage targets, security clean, API docs complete",
      "description_ru": "Финальная валидация: тесты, покрытие, безопасность, документация",
      "order": 4,
      "intent_keywords": ["gate", "validation", "final", "production", "готовность", "продакшен"]
    }
  },
  "steps": [
    {
      "order": 1,
      "role_id": "developer",
      "phase": "code_generation",
      "description": "Generate React components per architecture, implement API endpoints per contract, create database migrations, write utility functions",
      "parallel_with": ["ui-developer"],
      "deliverables": [
        "implementation_code",
        "api_endpoints",
        "database_migrations",
        "utility_functions"
      ],
      "exit_criteria": "Complete codebase matching architecture specifications",
      "timeout": "8h",
      "phase_join_criteria": {
        "required_artifacts": ["architecture_document", "api_contracts"],
        "prerequisites": ["Discovery Phase complete", "architecture approved"],
        "context_indicators": ["implement", "code", "build", "develop"],
        "skip_if": ["implementation exists"]
      }
    },
    {
      "order": 1,
      "role_id": "ui-developer",
      "phase": "code_generation",
      "description": "Implement UI components following UX specifications and design system",
      "parallel_with": ["developer"],
      "deliverables": [
        "react_components",
        "ui_tests",
        "storybook_stories"
      ],
      "exit_criteria": "UI implemented, responsive, and accessible",
      "timeout": "6h",
      "phase_join_criteria": {
        "required_artifacts": ["wireframes", "component_mapping"],
        "prerequisites": ["UX design approved"],
        "context_indicators": ["UI", "frontend", "components"],
        "skip_if": ["UI exists", "backend only"]
      }
    },
    {
      "order": 2,
      "role_id": "tester",
      "phase": "testing",
      "description": "Generate unit tests for business logic, create integration tests for APIs, write test fixtures and mocks, execute tests",
      "deliverables": [
        "unit_tests",
        "integration_tests",
        "test_fixtures",
        "coverage_report"
      ],
      "exit_criteria": "All tests pass with coverage ≥70% overall, ≥80% business logic",
      "timeout": "4h",
      "metadata": {
        "coverage_targets": {
          "overall": 70,
          "business_logic": 80
        },
        "test_enforcement": true
      },
      "phase_join_criteria": {
        "required_artifacts": ["implementation_code"],
        "prerequisites": ["code generation complete"],
        "context_indicators": ["test", "coverage", "unit", "integration"],
        "skip_if": ["tests exist and pass"]
      }
    },
    {
      "order": 3,
      "role_id": "code-reviewer",
      "phase": "code_review",
      "description": "Analyze code complexity, check security vulnerabilities, verify coding standards, identify code smells",
      "deliverables": [
        "code_review_report",
        "security_scan_results",
        "complexity_analysis"
      ],
      "exit_criteria": "Code approved with no critical issues",
      "timeout": "3h",
      "tools": ["ESLint", "TypeScript strict", "Security scanner"],
      "phase_join_criteria": {
        "required_artifacts": ["implementation_code", "unit_tests"],
        "prerequisites": ["tests pass"],
        "context_indicators": ["review", "check", "quality", "security"],
        "skip_if": []
      }
    },
    {
      "order": 4,
      "role_id": "test-architect",
      "phase": "quality_gate",
      "description": "Verify all quality gates: tests pass, coverage targets met, no critical vulnerabilities, complexity ≤10, API docs complete",
      "deliverables": [
        "quality_gate_report",
        "final_validation"
      ],
      "exit_criteria": "All quality gates pass - ready for production",
      "timeout": "2h",
      "escalation": "Failure triggers revision loop or human intervention (max 3 retries)",
      "quality_gates": {
        "all_tests_pass": true,
        "coverage": {
          "overall_min": 70,
          "business_logic_min": 80
        },
        "security": "zero_critical_high_vulnerabilities",
        "complexity": {
          "max_cyclomatic_per_function": 10
        },
        "build_succeeds": true,
        "api_documentation_complete": true
      },
      "phase_join_criteria": {
        "required_artifacts": ["code_review_report", "coverage_report"],
        "prerequisites": ["code review approved"],
        "context_indicators": ["gate", "validation", "production", "release"],
        "skip_if": []
      }
    }
  ],
  "estimated_time": "1.5-2 weeks",
  "success_criteria": "Production-ready code with all quality gates passed",
  "human_oversight": [
    "2-person team reviews quality gate results",
    "Expert approves deployment to production",
    "Expert intervenes if agents stuck (>3 retries)"
  ],
  "automated_quality_gates": [
    "All automated tests pass",
    "Code coverage ≥70% overall, ≥80% business logic",
    "Zero critical/high security vulnerabilities",
    "Cyclomatic complexity ≤10 per function",
    "Build succeeds",
    "API documentation complete"
  ],
  "output_artifacts": [
    "implementation_code",
    "unit_tests",
    "integration_tests",
    "coverage_report",
    "code_review_report",
    "quality_gate_report"
  ],
  "metadata": {
    "bmad": true,
    "phase": "0",
    "phase_name": "implementation-phase",
    "adaptive_phase_detection": true,
    "multi_agent_flow": "Developer + UI-Developer → Tester → Code Reviewer → Test Architect (QA Gate)",
    "principles": [
      "test_enforcement",
      "quality_gates",
      "security_first"
    ]
  }
}
