{
  "id": "discovery_phase_full",
  "name": "Full Discovery Phase",
  "description": "Complete Discovery Phase: BA → Architect (Tech Feasibility) → UX → Validation. Semi-automated, 3-5 days. Generates all artifacts for Implementation Phase.",
  "trigger_condition": {
    "keywords": [
      "discovery",
      "new product",
      "new feature",
      "product discovery",
      "requirements gathering",
      "дискавери",
      "новый продукт",
      "сбор требований"
    ],
    "task_types": [
      "discovery",
      "product",
      "planning",
      "requirements"
    ],
    "required_skills": [
      "requirements",
      "architecture_decisions",
      "user_flows"
    ],
    "complexity_range": ["complex", "enterprise"]
  },
  "phases": {
    "requirements": {
      "description": "Business requirements gathering and PRD creation",
      "description_ru": "Сбор бизнес-требований и создание PRD",
      "order": 1,
      "intent_keywords": ["requirements", "prd", "user story", "требования", "истории"]
    },
    "feasibility": {
      "description": "Technical feasibility analysis and tech stack validation",
      "description_ru": "Анализ технической осуществимости и валидация технологий",
      "order": 2,
      "intent_keywords": ["feasibility", "tech stack", "validation", "осуществимость", "технологии"]
    },
    "architecture": {
      "description": "System architecture design, DB schema, API contracts",
      "description_ru": "Проектирование архитектуры, схемы БД, API контрактов",
      "order": 3,
      "intent_keywords": ["architecture", "design", "schema", "api", "архитектура", "схема"]
    },
    "ux_design": {
      "description": "UX design, wireframes, component mapping",
      "description_ru": "UX дизайн, wireframes, маппинг компонентов",
      "order": 4,
      "intent_keywords": ["ux", "wireframe", "design", "flow", "дизайн", "прототип"]
    },
    "validation": {
      "description": "Cross-validate all artifacts for consistency and completeness",
      "description_ru": "Кросс-валидация всех артефактов на консистентность",
      "order": 5,
      "intent_keywords": ["validate", "check", "review", "валидация", "проверка"]
    }
  },
  "steps": [
    {
      "order": 1,
      "role_id": "business-analyst",
      "phase": "requirements",
      "description": "Gather requirements via Q&A, create user stories with acceptance criteria",
      "deliverables": [
        "prd_document",
        "user_stories",
        "acceptance_criteria",
        "user_role_definitions"
      ],
      "exit_criteria": "PRD complete with all user stories and acceptance criteria defined",
      "timeout": "4h",
      "requires_approval": true,
      "human_touchpoint": "Expert facilitates client requirements gathering",
      "phase_join_criteria": {
        "required_artifacts": [],
        "prerequisites": ["product vision defined"],
        "context_indicators": ["new product", "new feature", "requirements needed"],
        "skip_if": ["PRD already exists"]
      }
    },
    {
      "order": 2,
      "role_id": "architect",
      "phase": "feasibility",
      "description": "Technical feasibility analysis, tech stack validation, dependency identification, risk assessment",
      "deliverables": [
        "technical_specification_document",
        "tech_stack_validation",
        "dependency_map",
        "risk_assessment"
      ],
      "exit_criteria": "Technical feasibility confirmed with validated tech stack",
      "timeout": "3h",
      "phase_join_criteria": {
        "required_artifacts": ["prd_document"],
        "prerequisites": ["PRD approved"],
        "context_indicators": ["technical validation needed", "feasibility check"],
        "skip_if": ["technical spec exists"]
      }
    },
    {
      "order": 3,
      "role_id": "architect",
      "phase": "architecture",
      "description": "Design system architecture, database schema (ER diagrams), API contracts (OpenAPI), auth flows",
      "deliverables": [
        "architecture_document",
        "database_schema",
        "er_diagrams",
        "api_contracts",
        "auth_flow_diagrams",
        "adr_documents"
      ],
      "exit_criteria": "Complete architecture documentation with DB schema and API contracts",
      "timeout": "6h",
      "requires_approval": true,
      "phase_join_criteria": {
        "required_artifacts": ["technical_specification_document"],
        "prerequisites": ["technical feasibility confirmed"],
        "context_indicators": ["architecture", "design", "schema", "api"],
        "skip_if": ["architecture exists"]
      }
    },
    {
      "order": 4,
      "role_id": "ux-designer",
      "phase": "ux_design",
      "description": "Component selection from libraries, wireframes, navigation structure, form layouts",
      "deliverables": [
        "component_mapping",
        "wireframes",
        "user_flows",
        "navigation_structure",
        "form_layouts"
      ],
      "exit_criteria": "Complete UX specification with wireframes and component mapping",
      "timeout": "4h",
      "limitation": "Cannot create custom visual designs, only component-based wireframes",
      "phase_join_criteria": {
        "required_artifacts": ["prd_document", "architecture_document"],
        "prerequisites": ["PRD and architecture approved"],
        "context_indicators": ["ux", "wireframe", "design", "ui"],
        "skip_if": ["UX design exists", "backend only feature"]
      }
    },
    {
      "order": 5,
      "role_id": "requirements-validator",
      "phase": "validation",
      "description": "Cross-validate all artifacts for consistency, completeness, and conflicts",
      "deliverables": [
        "validation_report",
        "consistency_check",
        "completeness_matrix"
      ],
      "exit_criteria": "All artifacts validated and consistent",
      "timeout": "2h",
      "escalation": "Failure triggers human expert review",
      "phase_join_criteria": {
        "required_artifacts": ["prd_document", "architecture_document", "wireframes"],
        "prerequisites": ["all discovery artifacts created"],
        "context_indicators": ["validate", "check", "review"],
        "skip_if": []
      }
    }
  ],
  "estimated_time": "3-5 days",
  "success_criteria": "Complete Discovery artifacts ready for Implementation Phase: PRD, Technical Spec, Architecture, DB Schema, API Contracts, UX Wireframes, Validation Report",
  "human_touchpoints": [
    "Expert facilitates client requirements gathering",
    "Expert guides client through agent Q&A",
    "Expert reviews Discovery artifacts before approval",
    "One revision cycle allowed"
  ],
  "output_artifacts": [
    "prd_document",
    "technical_specification_document",
    "architecture_document",
    "database_schema",
    "api_contracts",
    "wireframes",
    "validation_report"
  ],
  "metadata": {
    "bmad": true,
    "phase": "0",
    "phase_name": "discovery-phase",
    "adaptive_phase_detection": true,
    "multi_agent_flow": "BA → Architect (Tech) → Architect (Design) → UX → Validation"
  }
}
