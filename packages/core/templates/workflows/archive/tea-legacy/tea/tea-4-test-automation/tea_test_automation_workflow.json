{
  "id": "tea_test_automation_workflow",
  "name": "TEA Test Automation Workflow",
  "description": "Plan and implement test automation framework and automated tests.",
  "trigger_condition": {
    "keywords": [
      "test automation",
      "automate",
      "automation framework",
      "automated testing",
      "автоматизация"
    ],
    "task_types": [
      "test_automation",
      "testing",
      "qa"
    ],
    "required_skills": [
      "test_automation",
      "code_writing"
    ]
  },
  "context_dependencies": [
    "test-strategy",
    "story"
  ],
  "steps": [
    {
      "order": 1,
      "role_id": "test-architect",
      "phase": "automation_scope",
      "description": "Define automation scope and ROI analysis",
      "deliverables": [
        "automation_scope"
      ],
      "exit_criteria": "Tests to automate selected based on ROI",
      "timeout": "20m"
    },
    {
      "order": 2,
      "role_id": "test-architect",
      "phase": "tool_selection",
      "description": "Select and configure automation tools",
      "deliverables": [
        "tool_recommendations"
      ],
      "exit_criteria": "Tools selected and justified",
      "timeout": "15m"
    },
    {
      "order": 3,
      "role_id": "test-architect",
      "phase": "framework_design",
      "description": "Design test automation framework",
      "deliverables": [
        "framework_design"
      ],
      "exit_criteria": "Framework architecture defined",
      "timeout": "25m"
    },
    {
      "order": 4,
      "role_id": "tester",
      "phase": "implementation",
      "description": "Implement automated tests",
      "deliverables": [
        "automated_tests"
      ],
      "exit_criteria": "Priority tests automated",
      "timeout": "60m"
    },
    {
      "order": 5,
      "role_id": "devops",
      "phase": "ci_integration",
      "description": "Integrate with CI/CD pipeline",
      "deliverables": [
        "ci_configuration"
      ],
      "exit_criteria": "Tests run in CI pipeline",
      "timeout": "20m"
    }
  ],
  "estimated_time": "2h 20m",
  "success_criteria": "Automated tests running in CI pipeline"
}
