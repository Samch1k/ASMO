{
  "id": "tea_risk_assessment_workflow",
  "name": "TEA Risk Assessment Workflow",
  "description": "Perform risk-based testing assessment to prioritize testing efforts based on business and technical risk.",
  "trigger_condition": {
    "keywords": [
      "risk assessment",
      "test risk",
      "risk-based testing",
      "quality risk",
      "оценка рисков"
    ],
    "task_types": [
      "test_strategy",
      "risk_assessment",
      "quality_assurance"
    ],
    "required_skills": [
      "risk_based_testing",
      "test_strategy"
    ]
  },
  "context_dependencies": [
    "prd",
    "architecture"
  ],
  "steps": [
    {
      "order": 1,
      "role_id": "test-architect",
      "phase": "business_risk",
      "description": "Identify and assess business risk areas",
      "deliverables": [
        "business_risk_matrix"
      ],
      "exit_criteria": "Business risks identified and prioritized",
      "timeout": "25m"
    },
    {
      "order": 2,
      "role_id": "test-architect",
      "phase": "technical_risk",
      "description": "Identify and assess technical risk areas",
      "deliverables": [
        "technical_risk_matrix"
      ],
      "exit_criteria": "Technical risks identified and prioritized",
      "timeout": "25m"
    },
    {
      "order": 3,
      "role_id": "test-architect",
      "phase": "risk_prioritization",
      "description": "Create combined risk matrix and testing priorities",
      "deliverables": [
        "combined_risk_matrix",
        "test_priorities"
      ],
      "exit_criteria": "Test areas prioritized by risk level",
      "timeout": "20m"
    },
    {
      "order": 4,
      "role_id": "test-architect",
      "phase": "mitigation_strategies",
      "description": "Define risk mitigation strategies for high-risk areas",
      "deliverables": [
        "mitigation_strategies"
      ],
      "exit_criteria": "Mitigation approach defined for each high-risk area",
      "timeout": "15m"
    }
  ],
  "estimated_time": "1h 25m",
  "success_criteria": "Complete risk assessment with prioritized testing areas"
}
