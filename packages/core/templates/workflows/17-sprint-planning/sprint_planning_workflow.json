{
  "id": "sprint_planning_workflow",
  "name": "Sprint Planning Workflow",
  "description": "Initialize sprint with selected stories, capacity planning, and sprint goals.",
  "trigger_condition": {
    "keywords": [
      "sprint planning",
      "new sprint",
      "start sprint",
      "sprint kickoff",
      "iteration planning",
      "планирование спринта"
    ],
    "task_types": [
      "sprint_planning",
      "planning",
      "agile_management"
    ],
    "required_skills": [
      "sprint_planning",
      "backlog_management",
      "agile_ceremonies"
    ]
  },
  "context_dependencies": [
    "epics",
    "prd"
  ],
  "steps": [
    {
      "order": 1,
      "role_id": "scrum-master",
      "phase": "capacity_planning",
      "description": "Calculate team capacity and velocity for the sprint",
      "deliverables": [
        "capacity_plan"
      ],
      "exit_criteria": "Team capacity determined",
      "timeout": "15m"
    },
    {
      "order": 2,
      "role_id": "product-owner",
      "phase": "story_selection",
      "description": "Select stories from backlog based on priority and capacity",
      "deliverables": [
        "sprint_backlog"
      ],
      "exit_criteria": "Sprint backlog selected within capacity",
      "timeout": "20m"
    },
    {
      "order": 3,
      "role_id": "scrum-master",
      "phase": "goal_definition",
      "description": "Define sprint goal and success criteria",
      "deliverables": [
        "sprint_goal"
      ],
      "exit_criteria": "Clear sprint goal established",
      "timeout": "10m"
    },
    {
      "order": 4,
      "role_id": "developer",
      "phase": "task_breakdown",
      "description": "Break down stories into technical tasks",
      "deliverables": [
        "task_list"
      ],
      "exit_criteria": "All stories have implementation tasks",
      "timeout": "25m"
    },
    {
      "order": 5,
      "role_id": "architect",
      "phase": "technical_review",
      "description": "Review technical approach for complex stories",
      "deliverables": [
        "technical_notes"
      ],
      "exit_criteria": "Technical approach validated for complex stories",
      "timeout": "15m"
    },
    {
      "order": 6,
      "role_id": "project-manager",
      "phase": "sprint_kickoff",
      "description": "Document sprint plan and communicate to team",
      "deliverables": [
        "sprint_plan_document"
      ],
      "exit_criteria": "Sprint plan documented and shared",
      "timeout": "10m"
    }
  ],
  "estimated_time": "1h 35m",
  "success_criteria": "Sprint initialized with clear goal, backlog, and task breakdown"
}
