{
  "id": "feature_implementation_full",
  "name": "Full Feature Implementation",
  "description": "Complete feature lifecycle: Design → Implement → Test → Deploy",
  "trigger_condition": {
    "keywords": [
      "implement feature",
      "new feature",
      "add functionality",
      "create feature",
      "реализуй фичу",
      "новая функция"
    ],
    "task_types": [
      "feature"
    ],
    "required_skills": [
      "architecture_decisions",
      "code_writing",
      "feature_implementation"
    ]
  },
  "phases": {
    "design": {
      "description": "Architecture design, ADR creation, and UX design",
      "description_ru": "Проектирование архитектуры, создание ADR, UX дизайн",
      "order": 1,
      "intent_keywords": ["design", "architect", "plan", "ux", "wireframe", "спроектировать", "архитектура"]
    },
    "implementation": {
      "description": "Backend and frontend implementation with unit tests",
      "description_ru": "Реализация бэкенда и фронтенда с юнит-тестами",
      "order": 2,
      "intent_keywords": ["implement", "code", "develop", "build", "реализовать", "написать код", "разработать"]
    },
    "testing": {
      "description": "E2E testing and integration testing",
      "description_ru": "E2E тестирование и интеграционное тестирование",
      "order": 3,
      "intent_keywords": ["test", "e2e", "integration", "qa", "тестировать", "проверить"]
    },
    "deployment": {
      "description": "Deployment to staging/production environment",
      "description_ru": "Деплой в staging/production окружение",
      "order": 4,
      "intent_keywords": ["deploy", "release", "ship", "staging", "production", "деплой", "выкатить"]
    }
  },
  "steps": [
    {
      "order": 1,
      "role_id": "architect",
      "phase": "design",
      "description": "Design architecture and create ADR",
      "parallel_with": ["ux-designer"],
      "deliverables": [
        "adr",
        "component_structure",
        "api_design"
      ],
      "exit_criteria": "Architecture documented and approved",
      "timeout": "20m",
      "phase_join_criteria": {
        "required_artifacts": [],
        "prerequisites": ["requirements defined"],
        "context_indicators": ["new feature", "greenfield", "no architecture"],
        "skip_if": ["architecture exists", "ADR exists"]
      }
    },
    {
      "order": 1,
      "role_id": "ux-designer",
      "phase": "design",
      "description": "Design user experience and UI flows",
      "parallel_with": ["architect"],
      "deliverables": [
        "user_flows",
        "wireframes",
        "component_specifications"
      ],
      "exit_criteria": "UX design completed and approved",
      "timeout": "20m",
      "phase_join_criteria": {
        "required_artifacts": [],
        "prerequisites": ["requirements defined"],
        "context_indicators": ["new UI", "user-facing feature"],
        "skip_if": ["UX design exists", "backend only"]
      }
    },
    {
      "order": 2,
      "role_id": "developer",
      "phase": "implementation",
      "description": "Implement backend logic and APIs with unit tests",
      "parallel_with": ["ui-developer"],
      "deliverables": [
        "code",
        "api_endpoints",
        "unit_tests",
        "documentation"
      ],
      "exit_criteria": "Backend implemented and unit tests pass",
      "timeout": "60m",
      "phase_join_criteria": {
        "required_artifacts": ["architecture design"],
        "prerequisites": ["design approved"],
        "context_indicators": ["implement", "code", "build"],
        "skip_if": ["implementation exists"]
      }
    },
    {
      "order": 2,
      "role_id": "ui-developer",
      "phase": "implementation",
      "description": "Implement UI components following UX specifications",
      "parallel_with": ["developer"],
      "deliverables": [
        "react_components",
        "ui_tests",
        "storybook_stories"
      ],
      "exit_criteria": "UI implemented, responsive, and accessible",
      "timeout": "40m",
      "phase_join_criteria": {
        "required_artifacts": ["UX design"],
        "prerequisites": ["UX approved"],
        "context_indicators": ["UI", "frontend", "components"],
        "skip_if": ["UI exists", "backend only"]
      }
    },
    {
      "order": 3,
      "role_id": "tester",
      "phase": "testing",
      "description": "Create and run E2E tests",
      "deliverables": [
        "e2e_tests",
        "test_results"
      ],
      "exit_criteria": "All E2E tests pass",
      "timeout": "30m",
      "phase_join_criteria": {
        "required_artifacts": ["implementation code"],
        "prerequisites": ["implementation complete"],
        "context_indicators": ["test", "e2e", "integration", "qa"],
        "skip_if": ["tests exist and pass"]
      }
    },
    {
      "order": 4,
      "role_id": "devops",
      "phase": "deployment",
      "description": "Deploy to staging environment",
      "deliverables": [
        "deployment_logs"
      ],
      "exit_criteria": "Deployed to staging successfully",
      "timeout": "15m",
      "requires_approval": true,
      "phase_join_criteria": {
        "required_artifacts": ["passing tests"],
        "prerequisites": ["all tests pass"],
        "context_indicators": ["deploy", "release", "ship"],
        "skip_if": []
      }
    }
  ],
  "estimated_time": "2h 25m",
  "success_criteria": "Feature deployed and working in staging with UX-designed UI",
  "metadata": {
    "adaptive_phase_detection": true
  }
}