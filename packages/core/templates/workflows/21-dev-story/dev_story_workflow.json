{
  "id": "dev_story_workflow",
  "name": "Dev Story Workflow (TDD)",
  "description": "TDD-based story implementation with 100% test coverage (Amelia's way). Follows Red-Green-Refactor cycle with strict test enforcement.",
  "trigger_condition": {
    "keywords": [
      "implement story",
      "develop story",
      "feature implementation",
      "dev story",
      "реализовать историю",
      "разработать историю",
      "история для разработки"
    ],
    "task_types": [
      "development",
      "implementation",
      "feature"
    ],
    "required_skills": [
      "coding",
      "testing",
      "implementation",
      "tdd_workflow"
    ]
  },
  "context_dependencies": [
    "story",
    "acceptance_criteria"
  ],
  "phases": {
    "test_first": {
      "description": "Write failing tests covering acceptance criteria (TDD Red phase)",
      "description_ru": "Написание падающих тестов по acceptance criteria (TDD Red фаза)",
      "order": 1,
      "intent_keywords": ["test first", "write tests", "tdd", "red phase", "тесты сначала", "написать тесты"]
    },
    "implementation": {
      "description": "Implement minimum code to pass tests (TDD Green phase)",
      "description_ru": "Реализация минимального кода для прохождения тестов (TDD Green фаза)",
      "order": 2,
      "intent_keywords": ["implement", "code", "develop", "build", "green phase", "реализовать", "написать код"]
    },
    "refactoring": {
      "description": "Clean up code while maintaining test coverage (TDD Refactor phase)",
      "description_ru": "Рефакторинг кода с сохранением тестового покрытия (TDD Refactor фаза)",
      "order": 3,
      "intent_keywords": ["refactor", "clean", "improve", "optimize", "рефакторинг", "улучшить", "оптимизировать"]
    },
    "review": {
      "description": "Code review for quality, security, and best practices",
      "description_ru": "Ревью кода на качество, безопасность и лучшие практики",
      "order": 4,
      "intent_keywords": ["review", "check", "verify", "audit", "security", "ревью", "проверить", "безопасность"]
    }
  },
  "steps": [
    {
      "order": 1,
      "role_id": "developer",
      "phase": "test_first",
      "description": "Write failing tests (Red phase) - TDD Step 1",
      "deliverables": [
        "test_suite",
        "failing_tests"
      ],
      "exit_criteria": "All acceptance criteria covered by failing tests",
      "timeout": "30m",
      "phase_join_criteria": {
        "required_artifacts": [],
        "prerequisites": ["story defined", "acceptance criteria available"],
        "context_indicators": ["no existing tests", "new feature", "greenfield"],
        "skip_if": []
      }
    },
    {
      "order": 2,
      "role_id": "developer",
      "phase": "implementation",
      "description": "Implement code to pass tests (Green phase) - TDD Step 2",
      "deliverables": [
        "implementation_code",
        "passing_tests"
      ],
      "exit_criteria": "All tests passing with 100% coverage",
      "timeout": "1h",
      "metadata": {
        "test_enforcement": true,
        "min_coverage": 100
      },
      "phase_join_criteria": {
        "required_artifacts": ["test files exist"],
        "prerequisites": ["tests written", "tests failing (red)"],
        "context_indicators": ["tests exist but failing", "implementation needed"],
        "skip_if": ["implementation already exists", "tests already passing"]
      }
    },
    {
      "order": 3,
      "role_id": "developer",
      "phase": "refactoring",
      "description": "Refactor while keeping tests green (Refactor phase) - TDD Step 3",
      "deliverables": [
        "refactored_code",
        "clean_code"
      ],
      "exit_criteria": "Code clean and all tests still passing",
      "timeout": "20m",
      "metadata": {
        "test_enforcement": true
      },
      "phase_join_criteria": {
        "required_artifacts": ["implementation code", "passing tests"],
        "prerequisites": ["implementation complete", "tests passing (green)"],
        "context_indicators": ["code needs cleanup", "refactor", "optimize", "clean up"],
        "skip_if": ["code already clean", "no refactoring needed"]
      }
    },
    {
      "order": 4,
      "role_id": "code-reviewer",
      "phase": "review",
      "description": "Review code quality and test coverage",
      "deliverables": [
        "review_feedback",
        "approval_or_changes"
      ],
      "exit_criteria": "Code approved or actionable feedback provided",
      "timeout": "15m",
      "phase_join_criteria": {
        "required_artifacts": ["implementation code"],
        "prerequisites": ["code exists"],
        "context_indicators": ["review", "check", "verify", "audit", "security", "ревью", "проверить"],
        "skip_if": []
      }
    }
  ],
  "estimated_time": "2h 5m",
  "success_criteria": "Story implemented with 100% passing tests following TDD cycle",
  "metadata": {
    "bmad": true,
    "principles": [
      "test_enforcement",
      "tdd"
    ],
    "inspired_by": "Amelia (Developer)",
    "phase": "21",
    "phase_name": "dev-story",
    "adaptive_phase_detection": true
  }
}
