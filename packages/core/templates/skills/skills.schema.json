{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://meatconnect.com/schemas/skills.schema.json",
  "title": "Agent Skills Configuration Schema",
  "description": "JSON Schema for validating AI agent skill configurations",
  "type": "object",
  "required": ["version", "skills"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the skills configuration format"
    },
    "skills": {
      "type": "array",
      "description": "Array of skill definitions",
      "items": {
        "$ref": "#/definitions/skill"
      },
      "minItems": 1
    }
  },
  "definitions": {
    "skill": {
      "type": "object",
      "required": [
        "id",
        "name",
        "description",
        "category",
        "complexity",
        "required_mcps",
        "confidence_threshold"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z_]+$",
          "description": "Unique skill identifier (snake_case)",
          "examples": ["code_writing", "e2e_testing", "deployment", "architecture_decisions"]
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable skill name",
          "examples": ["Code Writing", "E2E Testing", "Deployment", "Architecture Decisions"]
        },
        "description": {
          "type": "string",
          "minLength": 10,
          "description": "Detailed description of what this skill enables"
        },
        "category": {
          "type": "string",
          "enum": [
            "infrastructure",
            "development",
            "testing",
            "architecture",
            "business_logic",
            "devops",
            "design",
            "analysis",
            "debugging",
            "performance",
            "product",
            "project_management",
            "project_specific",
            "superpowers_workflows"
          ],
          "description": "Skill classification category"
        },
        "complexity": {
          "type": "string",
          "enum": ["basic", "intermediate", "advanced", "expert"],
          "description": "Complexity level of the skill"
        },
        "requires_skills": {
          "type": "array",
          "description": "Prerequisite skill IDs that must be present before using this skill",
          "items": {
            "type": "string",
            "pattern": "^[a-z_]+$"
          },
          "uniqueItems": true,
          "default": []
        },
        "required_mcps": {
          "type": "array",
          "description": "MCP servers required to execute this skill",
          "items": {
            "type": "string",
            "enum": [
              "filesystem",
              "memory",
              "supabase",
              "context7",
              "github",
              "playwright",
              "render",
              "vercel"
            ]
          },
          "uniqueItems": true
        },
        "confidence_threshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Minimum confidence score (0-1) required for agent to claim this skill"
        },
        "estimated_time": {
          "type": "string",
          "pattern": "^(\\d+[smhd]|N/A)$",
          "description": "Estimated time to complete task using this skill (e.g., '30m', '2h', 'N/A')",
          "examples": ["30m", "1h", "45m", "2h", "N/A"]
        },
        "composable_with": {
          "type": "array",
          "description": "Skill IDs that can be executed in parallel with this skill",
          "items": {
            "type": "string",
            "pattern": "^[a-z_]+$"
          },
          "uniqueItems": true,
          "default": []
        },
        "metadata": {
          "type": "object",
          "description": "Additional skill-specific metadata",
          "properties": {
            "tools": {
              "type": "array",
              "description": "Tools/frameworks associated with this skill",
              "items": {
                "type": "string"
              }
            },
            "documentation_links": {
              "type": "array",
              "description": "Reference documentation URLs",
              "items": {
                "type": "string",
                "format": "uri"
              }
            },
            "difficulty_level": {
              "type": "integer",
              "minimum": 1,
              "maximum": 10,
              "description": "Difficulty level (1-10)"
            },
            "success_rate": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Historical success rate (0-1)"
            },
            "aliases": {
              "type": "array",
              "description": "Alternative names for this skill",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    }
  }
}
