{
  "name": "@ai1st/core",
  "version": "0.1.0",
  "description": "AI1st orchestration system - autonomous AI development teams",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "ai",
    "orchestration",
    "multi-agent",
    "autonomous",
    "development",
    "automation",
    "llm"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@langchain/anthropic": "^0.3.7",
    "@langchain/core": "^0.3.24",
    "js-yaml": "^4.1.1",
    "lru-cache": "^11.2.5",
    "pg": "^8.17.2",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.5",
    "@types/pg": "^8.16.0",
    "@eslint/js": "^9.26.0",
    "typescript-eslint": "^8.32.1",
    "ajv": "^8.17.1",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "pg": "^8.17.2",
    "ts-jest": "^29.4.6",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "yaml": "^2.8.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
