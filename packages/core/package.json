{
  "name": "@asmo/core",
  "version": "1.0.0",
  "description": "ASMO orchestration system - autonomous AI development teams with library-first architecture",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/Samch1k/ASMO.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/Samch1k/ASMO#readme",
  "bugs": {
    "url": "https://github.com/Samch1k/ASMO/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "templates",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "ai",
    "orchestration",
    "multi-agent",
    "autonomous",
    "development",
    "automation",
    "llm"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "better-sqlite3": "^11.7.0",
    "js-yaml": "^4.1.1",
    "lru-cache": "^11.2.5",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/jest": "^29.5.11",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.5",
    "ajv": "^8.17.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.32.1",
    "yaml": "^2.8.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
