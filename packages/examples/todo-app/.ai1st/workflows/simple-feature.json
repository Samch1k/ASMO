{
  "id": "simple-feature",
  "name": "Simple Feature Implementation",
  "description": "Basic workflow for implementing simple features with design, implementation, and testing phases",
  "version": "1.0.0",
  "steps": [
    {
      "id": "design",
      "role": "architect",
      "phase": "design",
      "description": "Design the feature architecture and data models",
      "requiredSkills": ["system_design", "data_modeling"],
      "timeout": 180000,
      "approvalRequired": true
    },
    {
      "id": "implement",
      "role": "developer",
      "phase": "implementation",
      "description": "Implement the feature according to design",
      "requiredSkills": ["frontend_development", "react"],
      "timeout": 300000,
      "dependencies": ["design"],
      "approvalRequired": false
    },
    {
      "id": "test",
      "role": "tester",
      "phase": "testing",
      "description": "Test the feature functionality and edge cases",
      "requiredSkills": ["unit_testing", "integration_testing"],
      "timeout": 180000,
      "dependencies": ["implement"],
      "approvalRequired": true
    }
  ],
  "estimatedDuration": 660000,
  "tags": ["feature", "simple", "sequential"]
}
